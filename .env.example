# Search Typeahead — environment knobs. Copy to .env or export before `npm start`.
# Every value here is the DEFAULT used if the variable is unset (see config.js).

# ---- Server ----
PORT=3000                       # HTTP port the Express server listens on

# ---- Storage (SQLite source of truth) ----
DB_PATH=./data/typeahead.db     # SQLite file location (created by load-data)
# DATA_DIR defaults to ./data   # where the DB + downloaded dataset files live (gitignored)
SUGGESTION_LIMIT=10             # max suggestions returned by /suggest (top-N)

# ---- Cache: 3 independent Redis nodes (NOT Redis Cluster) ----
# Ports are fixed in docker-compose.yml; the app's ring targets these (see config.js REDIS_NODES):
#   node-1 -> 127.0.0.1:6379 , node-2 -> 127.0.0.1:6380 , node-3 -> 127.0.0.1:6381
VNODE_COUNT=150                 # virtual nodes per physical node on the consistent-hash ring (Ketama)
CACHE_TTL_SECONDS=300           # TTL safety-net for cached suggestion lists (seconds)

# ---- Trending / recency (Phase 5) ----
HALF_LIFE_SECONDS=3600          # exponential decay half-life for recency score (set small, e.g. 1, to watch decay)
RECENCY_ALPHA=0.5               # blend knob: score = ALPHA*normCount + (1-ALPHA)*normRecency
TRENDING_TTL_SECONDS=15         # short TTL for the global /trending list (it changes fast)
TRENDING_LIMIT=10               # number of entries returned by /trending

# ---- Write-behind batch writer (Phase 6) ----
BATCH_SIZE=500                  # flush when this many searches are buffered (size trigger); 1 ≈ synchronous-per-search
FLUSH_INTERVAL_MS=2000          # flush at least this often (timer trigger); whichever fires first
